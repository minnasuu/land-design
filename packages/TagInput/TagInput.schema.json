{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TagInput",
  "description": "标签输入框组件，允许用户通过输入创建和管理标签。支持回车添加、删除、限制数量等功能。",
  "type": "object",
  "properties": {
    "value": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          { "$ref": "#/definitions/TagItem" }
        ]
      },
      "description": "标签数据（受控模式），可以是字符串数组或 TagItem 数组"
    },
    "defaultValue": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          { "$ref": "#/definitions/TagItem" }
        ]
      },
      "description": "默认标签数据（非受控模式）"
    },
    "placeholder": {
      "type": "string",
      "description": "输入框占位符",
      "default": "按下回车以输入标签"
    },
    "maxCount": {
      "type": "number",
      "description": "最大标签数量",
      "default": 10
    },
    "maxTagLength": {
      "type": "number",
      "description": "单个标签最大长度（字符数）"
    },
    "allowDuplicate": {
      "type": "boolean",
      "description": "是否允许重复标签",
      "default": false
    },
    "variant": {
      "type": "string",
      "enum": ["outline", "fill"],
      "description": "外观变体：outline（描边样式）、fill（填充样式）",
      "default": "fill"
    },
    "size": {
      "type": "string",
      "enum": ["small", "default", "large"],
      "description": "尺寸",
      "default": "default"
    },
    "disabled": {
      "type": "boolean",
      "description": "是否禁用",
      "default": false
    },
    "readOnly": {
      "type": "boolean",
      "description": "是否只读",
      "default": false
    },
    "showClear": {
      "type": "boolean",
      "description": "是否显示清空按钮",
      "default": true
    },
    "className": {
      "type": "string",
      "description": "自定义类名"
    },
    "style": {
      "type": "object",
      "description": "自定义样式"
    },
    "width": {
      "type": ["number", "string"],
      "description": "宽度（支持数字或字符串）"
    },
    "tagClassName": {
      "type": "string",
      "description": "标签自定义类名"
    },
    "tagStyle": {
      "type": "object",
      "description": "标签自定义样式"
    },
    "renderTag": {
      "type": "function",
      "description": "自定义标签渲染，参数：(tag: string | TagItem, index: number, onClose: () => void) => ReactNode"
    },
    "prefix": {
      "type": "object",
      "description": "前置内容，传入 React 节点"
    },
    "suffix": {
      "type": "object",
      "description": "后置内容，传入 React 节点"
    },
    "onChange": {
      "type": "function",
      "description": "标签变化回调，参数：(tags: (string | TagItem)[], trigger: 'add' | 'remove' | 'clear') => void"
    },
    "onAdd": {
      "type": "function",
      "description": "添加标签回调，参数：(tag: string) => void"
    },
    "onRemove": {
      "type": "function",
      "description": "删除标签回调，参数：(tag: string | TagItem, index: number) => void"
    },
    "onClear": {
      "type": "function",
      "description": "清空回调，参数：() => void"
    },
    "onEnter": {
      "type": "function",
      "description": "回车回调，参数：(inputValue: string, e: KeyboardEvent) => void"
    },
    "onInputChange": {
      "type": "function",
      "description": "输入变化回调，参数：(value: string, e: ChangeEvent) => void"
    },
    "onFocus": {
      "type": "function",
      "description": "聚焦回调，参数：(e: FocusEvent) => void"
    },
    "onBlur": {
      "type": "function",
      "description": "失焦回调，参数：(e: FocusEvent) => void"
    }
  },
  "definitions": {
    "TagItem": {
      "type": "object",
      "description": "标签数据项对象",
      "properties": {
        "key": {
          "type": "string",
          "description": "标签唯一标识"
        },
        "label": {
          "type": "string",
          "description": "标签文本"
        },
        "closable": {
          "type": "boolean",
          "description": "是否可删除"
        },
        "style": {
          "type": "object",
          "description": "标签自定义样式"
        },
        "className": {
          "type": "string",
          "description": "标签自定义类名"
        }
      },
      "required": ["label"]
    },
    "TagInputVariant": {
      "type": "string",
      "enum": ["outline", "fill"],
      "description": "标签输入框外观变体"
    },
    "TagInputSize": {
      "type": "string",
      "enum": ["small", "default", "large"],
      "description": "标签输入框尺寸"
    }
  },
  "examples": [
    {
      "title": "基础用法",
      "props": {
        "placeholder": "按回车添加标签"
      }
    },
    {
      "title": "带默认值",
      "props": {
        "defaultValue": ["标签1", "标签2", "标签3"],
        "placeholder": "继续添加标签"
      }
    },
    {
      "title": "限制数量",
      "props": {
        "maxCount": 5,
        "placeholder": "最多5个标签"
      }
    },
    {
      "title": "描边样式",
      "props": {
        "variant": "outline",
        "placeholder": "描边样式"
      }
    },
    {
      "title": "禁用状态",
      "props": {
        "disabled": true,
        "defaultValue": ["禁用标签"]
      }
    }
  ]
}
