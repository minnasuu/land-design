{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Progress",
  "description": "进度条组件，用于展示操作或任务的当前进度。",
  "type": "object",
  "properties": {
    "value": {
      "type": "number",
      "default": 0.6,
      "description": "当前进度值，范围 0-1（对应 0%-100%）"
    },
    "type": {
      "type": "string",
      "enum": ["line", "circle"],
      "default": "line",
      "description": "进度条类型：line-线形、circle-环形"
    },
    "status": {
      "type": "string",
      "enum": ["default", "success", "fail"],
      "default": "default",
      "description": "进度条状态"
    },
    "strokeWidth": {
      "type": "number",
      "default": 8,
      "description": "线条宽度"
    },
    "hideLabel": {
      "type": "boolean",
      "default": false,
      "description": "是否隐藏进度数值"
    },
    "className": {
      "type": "string",
      "description": "自定义类名"
    },
    "style": {
      "type": "object",
      "description": "自定义样式"
    }
  },
  "examples": [
    {
      "description": "基础线形进度条",
      "code": "<Progress value={0.6} />"
    },
    {
      "description": "环形进度条",
      "code": "<Progress type=\"circle\" value={0.75} />"
    },
    {
      "description": "成功状态",
      "code": "<Progress value={1} status=\"success\" />"
    },
    {
      "description": "失败状态",
      "code": "<Progress value={0.3} status=\"fail\" />"
    },
    {
      "description": "隐藏数值",
      "code": "<Progress value={0.5} hideLabel />"
    }
  ]
}
