{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flex",
  "description": "弹性布局组件，基于 Flexbox",
  "type": "object",
  "properties": {
    "children": {
      "type": "ReactNode",
      "description": "子元素"
    },
    "column": {
      "type": "boolean",
      "description": "是否为垂直方向",
      "default": false
    },
    "wrap": {
      "type": "boolean",
      "description": "是否换行",
      "default": false
    },
    "justify": {
      "type": "string",
      "description": "主轴对齐方式",
      "enum": ["start", "center", "end", "space-between", "space-around"]
    },
    "align": {
      "type": "string",
      "description": "交叉轴对齐方式",
      "enum": ["start", "center", "end", "baseline"]
    },
    "bothCenter": {
      "type": "boolean",
      "description": "是否双向居中",
      "default": false
    },
    "width": {
      "type": "string",
      "description": "容器宽度"
    },
    "height": {
      "type": "string",
      "description": "容器高度"
    },
    "gap": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" }
      ],
      "description": "元素间隙"
    },
    "className": {
      "type": "string",
      "description": "自定义类名"
    },
    "style": {
      "type": "object",
      "description": "自定义样式"
    }
  },
  "examples": [
    {
      "description": "水平排列",
      "value": {
        "gap": 16
      }
    },
    {
      "description": "垂直居中",
      "value": {
        "column": true,
        "align": "center"
      }
    },
    {
      "description": "双向居中",
      "value": {
        "bothCenter": true,
        "height": "200px"
      }
    }
  ],
  "required": [],
  "additionalProperties": false
}
